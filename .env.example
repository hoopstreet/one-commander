# OpenRouter
OPENROUTER_API_KEY=op://Vault/OpenRouter/api_key

# Telegram
TELEGRAM_BOT_TOKEN=op://Vault/Telegram/bot_token
TELEGRAM_USER_ID=op://Vault/Telegram/user_id

# Supabase
SUPABASE_URL=op://Vault/Supabase/url
SUPABASE_ANON_KEY=op://Vault/Supabase/anon_key
SUPABASE_SERVICE_KEY=op://Vault/Supabase/service_key

# Gateway
OPENCLAW_GATEWAY_TOKEN=op://Vault/Gateway/token

# GitHub
GH_PAT=op://Vault/GitHub/pat

# Northflank
NORTHFLANK_TOKEN=op://Vault/Northflank/token

# Tailscale
TAILSCALE_AUTH_KEY=op://Vault/Tailscale/auth_key
TAILSCALE_API_KEY=op://Vault/Tailscale/api_key
TAILSCALE_CLIENT_ID=op://Vault/Tailscale/client_id

# SSH
SSH_PRIVATE_KEY=op://Vault/SSH/private_key
SSH_PUBLIC_KEY=op://Vault/SSH/public_key
SSH_USER=op://Vault/SSH/user
SSH_PASSWORD=op://Vault/SSH/password
SSH_PORT=op://Vault/SSH/port

# System
TZ=Asia/Manila
NODE_OPTIONS=-r /data/data/com.termux/files/home/hijack.js
